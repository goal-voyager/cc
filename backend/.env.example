# Copy this file to .env and fill in your own values
# MongoDB Atlas connection string (see README Step 2)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/craftconnect?retryWrites=true&w=majority

# Port the server runs on locally (Render sets its own automatically)
PORT=5000

# Any long random string - used to sign login tokens. Change this to your
# own random value (you can generate one by running:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# Comma separated list of frontend URLs allowed to call this API.
# Leave this line commented out / deleted while testing in Codespaces or
# locally - with it unset, the API allows requests from any origin, which is
# the easiest way to test. Only set it once you deploy the frontend to
# Netlify (see README Step 5), e.g.:
# CLIENT_ORIGIN=https://your-frontend-site.netlify.app
